{
  "$schema": "https://glama.ai/mcp/schemas/server.json",
  "maintainers": ["kjberk13"],
  "name": "patent-precheck-mcp",
  "description": "Score live code for patentability inside Cursor, Claude, and Codex — keyless hosted MCP with 1M+ prior-art corpus, USPTO pillar bands, rejection-risk preview, patent lookup/compare, and Interactive Code Review funnel. Unlike USPTO lookup MCPs, no API keys required.",
  "type": "mcp_server",
  "status": "stable",
  "framework": "Node.js @modelcontextprotocol/sdk",
  "tools": 12,
  "transport": ["stdio", "streamable-http"],
  "keywords": [
    "patent",
    "patentability",
    "prior-art",
    "uspto",
    "novelty",
    "software-patent",
    "cursor",
    "claude-code",
    "codex",
    "mcp-server",
    "ai-agent",
    "code-patent",
    "alice-test",
    "filing-readiness"
  ],
  "features": {
    "hosted_mcp": {
      "enabled": true,
      "url": "https://patentprecheck.com/mcp",
      "note": "Streamable HTTP — no npx, no API keys"
    },
    "patent_scoring": {
      "enabled": true,
      "tools": ["precheck_score", "precheck_pillars", "precheck_rejection_patterns", "precheck_legal_context"]
    },
    "prior_art": {
      "enabled": true,
      "tools": ["precheck_prior_art", "precheck_search_corpus"]
    },
    "patent_lookup": {
      "enabled": true,
      "tools": ["precheck_lookup_patent", "precheck_compare_to_patent"]
    },
    "interactive_code_review": {
      "enabled": true,
      "tools": ["precheck_start_review", "precheck_session_status", "precheck_deliverables"]
    }
  }
}
