{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.Patent-PreCheck/patent-precheck",
  "title": "Patent PreCheck",
  "description": "Keyless 12-tool patentability MCP — USPTO pillar scores, prior art, hosted at patentprecheck.com/mcp.",
  "version": "0.4.1",
  "websiteUrl": "https://patentprecheck.com/integrations",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@patentprecheck/mcp",
      "version": "0.4.1",
      "transport": {
        "type": "stdio"
      },
      "runtimeHint": "npx",
      "runtimeArguments": [
        {
          "type": "positional",
          "value": "mcp"
        }
      ]
    }
  ],
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://patentprecheck.com/mcp"
    }
  ]
}
